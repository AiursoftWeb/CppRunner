@model Aiursoft.CppRunner.Models.HomeViewModels.IndexViewModel
@{
    var firstLang = Model.Langs.FirstOrDefault();
}

@section styles {
    <style>
        .runner-page {
            display: flex;
            flex-direction: column;
            height: calc(100vh - 56px);
            overflow: hidden;
        }

        .runner-toolbar {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.5rem 1rem;
            background: var(--bs-body-bg);
            border-bottom: 1px solid var(--bs-border-color);
            flex-shrink: 0;
            flex-wrap: wrap;
        }

        .runner-body {
            display: flex;
            flex: 1;
            overflow: hidden;
            min-height: 0;
        }

        .runner-editor-pane {
            flex: 0 0 55%;
            display: flex;
            flex-direction: column;
            border-right: 2px solid var(--bs-border-color);
            min-width: 0;
        }

        #monaco-editor-container {
            flex: 1;
            min-height: 0;
        }

        .runner-right-pane {
            flex: 1;
            display: flex;
            flex-direction: column;
            min-width: 0;
            overflow: hidden;
        }

        .runner-output-pane,
        .runner-error-pane {
            flex: 1;
            display: flex;
            flex-direction: column;
            min-height: 0;
            overflow: hidden;
        }

        .runner-output-pane {
            border-bottom: 2px solid var(--bs-border-color);
        }

        .pane-header {
            padding: 0.4rem 1rem;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--bs-secondary-color);
            background: var(--bs-tertiary-bg);
            border-bottom: 1px solid var(--bs-border-color);
            flex-shrink: 0;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .pane-content {
            flex: 1;
            overflow-y: auto;
            overflow-x: auto;
            padding: 0.75rem 1rem;
            margin: 0;
            font-family: 'Cascadia Code', 'Fira Code', 'JetBrains Mono', Consolas, monospace;
            font-size: 0.8rem;
            line-height: 1.6;
            white-space: pre-wrap;
            word-break: break-word;
            background: transparent;
            border: none;
        }

        #output-panel { color: var(--bs-body-color); }
        #error-panel  { color: #dc3545; }

        .result-badge {
            font-size: 0.7rem;
            padding: 0.15em 0.5em;
            border-radius: 0.25rem;
        }

        #btn-run .spinner-border {
            width: 1rem;
            height: 1rem;
            border-width: 0.15em;
        }
    </style>
}

<div class="runner-page">

    <div class="runner-toolbar">
        <select id="lang-selector" class="form-select form-select-sm" style="max-width:260px;">
            @foreach (var lang in Model.Langs)
            {
                <option value="@lang.LangName">@lang.LangDisplayName</option>
            }
        </select>

        <button id="btn-run" class="btn btn-primary btn-sm" onclick="runCode()">
            <i data-lucide="play" class="me-1" style="width:14px;height:14px;"></i> @Localizer["Run"]
        </button>

        <span id="exit-code-badge" class="result-badge d-none"></span>
        <span id="run-status" class="text-muted small"></span>
        <span class="ms-auto text-muted small d-none d-md-inline">Ctrl+Enter to run</span>
    </div>

    <div class="runner-body">

        <div class="runner-editor-pane">
            <div class="pane-header">
                <i data-lucide="code-2" style="width:13px;height:13px;"></i>
                @Localizer["Source Code"]
            </div>
            <div id="monaco-editor-container"></div>
        </div>

        <div class="runner-right-pane">

            <div class="runner-output-pane">
                <div class="pane-header">
                    <i data-lucide="terminal" style="width:13px;height:13px;"></i>
                    @Localizer["Output"]
                </div>
                <pre class="pane-content" id="output-panel">@Localizer["Click Run (or Ctrl+Enter) to execute the code."]</pre>
            </div>

            <div class="runner-error-pane">
                <div class="pane-header">
                    <i data-lucide="triangle-alert" style="width:13px;height:13px;"></i>
                    @Localizer["Errors / Stderr"]
                </div>
                <pre class="pane-content" id="error-panel"></pre>
            </div>

        </div>
    </div>
</div>

@section scripts {
<script src="https://cdn.jsdelivr.net/npm/monaco-editor@0.52.2/min/vs/loader.js"></script>
<script>
    // ── Language data from server ─────────────────────────────────────────────
    const langDefaults = {};
    @foreach (var lang in Model.Langs)
    {
        <text>langDefaults[@Json.Serialize(lang.LangName)] = @Json.Serialize(lang.DefaultCode);
</text>
    }

    // Map our lang names → Monaco language IDs
    const monacoLangMap = {
        'c':              'c',
        'cpp':            'cpp',
        'cuda':           'cpp',
        'csharp':         'csharp',
        'go':             'go',
        'rust':           'rust',
        'javascript':     'javascript',
        'typescript':     'typescript',
        'python':         'python',
        'python-pytorch': 'python',
        'bash':           'shell',
        'powershell':     'powershell',
        'swift':          'swift',
        'java':           'java',
        'ruby':           'ruby',
        'php':            'php',
        'perl':           'perl',
        'lua':            'lua',
        'haskell':        'plaintext',
        'lisp':           'scheme',
    };

    // ── DOM refs ─────────────────────────────────────────────────────────────
    const langSelector = document.getElementById('lang-selector');
    const outputPanel  = document.getElementById('output-panel');
    const errorPanel   = document.getElementById('error-panel');
    const statusEl     = document.getElementById('run-status');
    const badgeEl      = document.getElementById('exit-code-badge');
    const btnRun       = document.getElementById('btn-run');

    // ── Monaco initialisation ─────────────────────────────────────────────────
    require.config({ paths: { vs: 'https://cdn.jsdelivr.net/npm/monaco-editor@0.52.2/min/vs' } });

    let editor;

    require(['vs/editor/editor.main'], function () {
        const firstLang = langSelector.value;

        editor = monaco.editor.create(document.getElementById('monaco-editor-container'), {
            value:           langDefaults[firstLang] ?? '',
            language:        monacoLangMap[firstLang] ?? 'plaintext',
            theme:           'vs-dark',
            fontSize:        14,
            lineNumbers:     'on',
            minimap:         { enabled: false },
            scrollBeyondLastLine: false,
            automaticLayout: true,
            tabSize:         4,
            insertSpaces:    true,
            wordWrap:        'off',
        });

        // Ctrl+Enter → run
        editor.addCommand(
            monaco.KeyMod.CtrlCmd | monaco.KeyCode.Enter,
            () => runCode()
        );

        // Language selector change
        langSelector.addEventListener('change', function () {
            const langName  = this.value;
            const monacoId  = monacoLangMap[langName] ?? 'plaintext';

            monaco.editor.setModelLanguage(editor.getModel(), monacoId);
            editor.setValue(langDefaults[langName] ?? '');

            outputPanel.textContent = '';
            errorPanel.textContent  = '';
            badgeEl.className = 'result-badge d-none';
            statusEl.textContent = '';
        });
    });

    // ── Run code ──────────────────────────────────────────────────────────────
    async function runCode() {
        if (!editor) return;

        const lang = langSelector.value;
        const code = editor.getValue();

        btnRun.disabled = true;
        btnRun.innerHTML = '<span class="spinner-border" role="status"></span>&nbsp;@Localizer["Running..."]';
        statusEl.textContent = '';
        outputPanel.textContent = '';
        errorPanel.textContent  = '';
        badgeEl.className = 'result-badge d-none';

        const startTime = Date.now();

        try {
            const response = await fetch('/Runner/run?lang=' + encodeURIComponent(lang), {
                method:  'POST',
                headers: { 'Content-Type': 'text/plain' },
                body:    code
            });

            if (!response.ok) {
                errorPanel.textContent = 'HTTP ' + response.status + ': ' + response.statusText;
                return;
            }

            const result  = await response.json();
            const elapsed = ((Date.now() - startTime) / 1000).toFixed(2);

            outputPanel.textContent = result.Output || '(no output)';
            errorPanel.textContent  = result.Error  || '';

            const exitOk = result.ResultCode === 0;
            badgeEl.textContent = 'Exit: ' + result.ResultCode;
            badgeEl.className   = 'result-badge badge ' + (exitOk ? 'bg-success' : 'bg-danger');
            statusEl.textContent = 'Completed in ' + elapsed + 's';

        } catch (err) {
            errorPanel.textContent = String(err);
        } finally {
            btnRun.disabled = false;
            btnRun.innerHTML = '<i data-lucide="play" class="me-1" style="width:14px;height:14px;"></i> @Localizer["Run"]';
            if (typeof lucide !== 'undefined') lucide.createIcons();
        }
    }

    if (typeof lucide !== 'undefined') lucide.createIcons();
</script>
}
