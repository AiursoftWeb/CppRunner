@model Aiursoft.CppRunner.Models.HomeViewModels.IndexViewModel

@*
    The following lines are for the localization scanner:
    @Localizer["Lua (5.4)"]
    @Localizer["TypeScript (4.9.3, node 16.8.1)"]
    @Localizer["C (gcc 15.2.0)"]
    @Localizer["Perl (5.39.5)"]
    @Localizer["Go (Golang 1.21.5)"]
    @Localizer["C++ (GNU G++, stdc++20)"]
    @Localizer["Rust (1.81)"]
    @Localizer["Lisp (rigetti/lisp)"]
    @Localizer["Python (CPython 3.11)"]
    @Localizer["CUDA 12.6.2 (on Ubuntu 24.04)"]
    @Localizer["PowerShell Core (Ubuntu 24.04)"]
    @Localizer["Javascript (Node.js v24)"]
    @Localizer["Bash (on Ubuntu 25.10)"]
    @Localizer["Haskell (GHC 9.8.1)"]
    @Localizer["Ruby (3.2.2)"]
    @Localizer["Java (OpenJDK 23)"]
    @Localizer["PHP (8.3.0)"]
    @Localizer["Python with PyTorch (Pytorch 2.7.0; cuda 12.6; cudnn 9)"]
    @Localizer["C# (.NET 7.0)"]
    @Localizer["Swift (5.8.1)"]
*@

@* ReSharper disable once Razor.SectionNotResolved *@
@section styles {
    <style>
        .runner-page {
            display: flex;
            flex-direction: column;
            height: calc(100vh - 56px);
            overflow: hidden;
        }

        .runner-toolbar {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.5rem 1rem;
            background: var(--bs-body-bg);
            border-bottom: 1px solid var(--bs-border-color);
            flex-shrink: 0;
            flex-wrap: wrap;
        }

        .runner-body {
            display: flex;
            flex: 1;
            overflow: hidden;
            min-height: 0;
        }

        .runner-editor-pane {
            flex: 0 0 55%;
            display: flex;
            flex-direction: column;
            border-right: 2px solid var(--bs-border-color);
            min-width: 0;
        }

        #monaco-editor-container {
            flex: 1;
            min-height: 0;
        }

        .runner-right-pane {
            flex: 1;
            display: flex;
            flex-direction: column;
            min-width: 0;
            overflow: hidden;
        }

        .runner-output-pane,
        .runner-error-pane {
            flex: 1;
            display: flex;
            flex-direction: column;
            min-height: 0;
            overflow: hidden;
        }

        .runner-output-pane {
            border-bottom: 2px solid var(--bs-border-color);
        }

        .pane-header {
            padding: 0.4rem 1rem;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--bs-secondary-color);
            background: var(--bs-tertiary-bg);
            border-bottom: 1px solid var(--bs-border-color);
            flex-shrink: 0;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        #output-panel-container,
        #error-panel-container {
            flex: 1;
            min-height: 0;
        }

        .result-badge {
            font-size: 0.7rem;
            padding: 0.15em 0.5em;
            border-radius: 0.25rem;
        }

        #btn-run .spinner-border {
            width: 1rem;
            height: 1rem;
            border-width: 0.15em;
        }

        /* ── Mobile: stack vertically ─────────────────────────────────── */
        @@media (max-width: 768px) {
            .runner-page {
                height: auto;
                overflow: visible;
            }

            .runner-body {
                flex-direction: column;
                overflow: visible;
                height: auto;
            }

            .runner-editor-pane {
                flex: none;
                height: 45vh;
                border-right: none;
                border-bottom: 2px solid var(--bs-border-color);
            }

            .runner-right-pane {
                flex: none;
                height: auto;
                overflow: visible;
            }

            .runner-output-pane {
                flex: none;
                height: 30vh;
            }

            .runner-error-pane {
                flex: none;
                height: 18vh;
            }
        }
    </style>
}

<div class="runner-page">

    <div class="runner-toolbar">
        <select id="lang-selector" class="form-select form-select-sm" style="max-width:260px;">
            @foreach (var lang in Model.Langs)
            {
                <option value="@lang.LangName">@Localizer[lang.LangDisplayName]</option>
            }
        </select>

        <button id="btn-run" class="btn btn-primary btn-sm" onclick="runCode()">
            <i data-lucide="play" class="me-1" style="width:14px;height:14px;"></i> @Localizer["Run"]
        </button>

        <button id="btn-save" class="btn btn-outline-secondary btn-sm d-none" onclick="handleSave(false)">
            <i data-lucide="save" class="me-1" style="width:14px;height:14px;"></i> @Localizer["Save"]
        </button>

        <button id="btn-save-as" class="btn btn-outline-secondary btn-sm d-none" onclick="handleSave(true)">
            <i data-lucide="copy" class="me-1" style="width:14px;height:14px;"></i> @Localizer["Save As"]
        </button>

        <span id="exit-code-badge" class="result-badge d-none"></span>
        <span id="run-status" class="text-muted small"></span>
        <span class="ms-auto text-muted small d-none d-md-inline">@Localizer["Ctrl+Enter to run"]</span>
    </div>

    <input type="hidden" id="localized-running" value="@Localizer["Running..."]" />
    <input type="hidden" id="localized-run" value="@Localizer["Run"]" />
    <input type="hidden" id="localized-timeout" value="@Localizer["Timeout"]" />
    <input type="hidden" id="localized-timed-out-after" value="@Localizer["Timed out after"]" />
    <input type="hidden" id="localized-completed-in" value="@Localizer["Completed in"]" />
    <input type="hidden" id="localized-click-run" value="@Localizer["Click Run (or Ctrl+Enter) to execute the code."]" />
    <input type="hidden" id="localized-no-output" value="@Localizer["(no output)"]" />
    <input type="hidden" id="localized-exit" value="@Localizer["Exit:"]" />

    <div class="runner-body">

        <div class="runner-editor-pane">
            <div class="pane-header">
                <i data-lucide="code-2" style="width:13px;height:13px;"></i>
                @Localizer["Source Code"]
            </div>
            <div id="monaco-editor-container"></div>
        </div>

        <div class="runner-right-pane">

            <div class="runner-output-pane">
                <div class="pane-header">
                    <i data-lucide="terminal" style="width:13px;height:13px;"></i>
                    @Localizer["Output"]
                </div>
                <div id="output-panel-container"></div>
            </div>

            <div class="runner-error-pane">
                <div class="pane-header">
                    <i data-lucide="triangle-alert" style="width:13px;height:13px;"></i>
                    @Localizer["Errors / Stderr"]
                </div>
                <div id="error-panel-container"></div>
            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="saveCodeModal" tabindex="-1" aria-labelledby="saveCodeModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="saveCodeModalLabel">@Localizer["Save Code"]</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label for="code-title" class="form-label">@Localizer["Title"]</label>
                    <input type="text" class="form-control" id="code-title" placeholder="@Localizer["Give your code a title"]">
                </div>
                <div class="form-check form-switch mb-2">
                    <input class="form-check-input" type="checkbox" id="is-public-switch">
                    <label class="form-check-label" for="is-public-switch">@Localizer["Make it public (all people can see it)"]</label>
                </div>
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" id="save-result-switch">
                    <label class="form-check-label" for="save-result-switch">@Localizer["Save execution results and error messages"]</label>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@Localizer["Cancel"]</button>
                <button type="button" class="btn btn-primary" id="btn-confirm-save" onclick="confirmSave()">@Localizer["Save"]</button>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@* ReSharper disable once Razor.SectionNotResolved *@
@section scripts {
<script src="https://cdn.jsdelivr.net/npm/monaco-editor@0.52.2/min/vs/loader.js"></script>
<script>
    // ── Language data from server ─────────────────────────────────────────────
    const langDefaults = {};
    @foreach (var lang in Model.Langs)
    {
        <text>langDefaults[@Json.Serialize(lang.LangName)] = @Json.Serialize(lang.DefaultCode);
</text>
    }

    // Map our lang names → Monaco language IDs
    const monacoLangMap = {
        'c':              'c',
        'cpp':            'cpp',
        'cuda':           'cpp',
        'csharp':         'csharp',
        'go':             'go',
        'rust':           'rust',
        'javascript':     'javascript',
        'typescript':     'typescript',
        'python':         'python',
        'python-pytorch': 'python',
        'bash':           'shell',
        'powershell':     'powershell',
        'swift':          'swift',
        'java':           'java',
        'ruby':           'ruby',
        'php':            'php',
        'perl':           'perl',
        'lua':            'lua',
        'haskell':        'plaintext',
        'lisp':           'scheme',
    };

    // ── DOM refs ─────────────────────────────────────────────────────────────
    const langSelector = document.getElementById('lang-selector');
    const statusEl     = document.getElementById('run-status');
    const badgeEl      = document.getElementById('exit-code-badge');
    const btnRun       = document.getElementById('btn-run');
    let lastResultCode = null;

    const localizedRunning      = document.getElementById('localized-running').value;
    const localizedRun          = document.getElementById('localized-run').value;
    const localizedTimeout      = document.getElementById('localized-timeout').value;
    const localizedTimedOutAfter = document.getElementById('localized-timed-out-after').value;
    const localizedCompletedIn  = document.getElementById('localized-completed-in').value;
    const localizedClickRun     = document.getElementById('localized-click-run').value;
    const localizedNoOutput     = document.getElementById('localized-no-output').value;
    const localizedExit         = document.getElementById('localized-exit').value;

    // ── Monaco initialisation ─────────────────────────────────────────────────
    require.config({ paths: { vs: 'https://cdn.jsdelivr.net/npm/monaco-editor@0.52.2/min/vs' } });

    let editor, outputEditor, errorEditor;

    require(['vs/editor/editor.main'], function () {
        const preLoadedId = @Json.Serialize(Model.PreLoadedId);
        const preLoadedCode = @Json.Serialize(Model.PreLoadedCode);
        const preLoadedLang = @Json.Serialize(Model.PreLoadedLang);
        const preLoadedTitle = @Json.Serialize(Model.PreLoadedTitle);
        const preLoadedResult = @Json.Serialize(Model.PreLoadedResult);
        const preLoadedError = @Json.Serialize(Model.PreLoadedError);
        const preLoadedResultCode = @Json.Serialize(Model.PreLoadedResultCode);

        let initialCode = preLoadedCode;
        let initialLang = preLoadedLang;

        if (preLoadedLang) {
            langSelector.value = preLoadedLang;
        }

        const firstLang = langSelector.value;
        if (!initialCode) {
            initialCode = langDefaults[firstLang] ?? '';
        }
        if (!initialLang) {
            initialLang = firstLang;
        }

        editor = monaco.editor.create(document.getElementById('monaco-editor-container'), {
            value:           initialCode,
            language:        monacoLangMap[firstLang] ?? 'plaintext',
            theme:           'vs-dark',
            fontSize:        14,
            lineNumbers:     'on',
            minimap:         { enabled: false },
            scrollBeyondLastLine: false,
            automaticLayout: true,
            tabSize:         4,
            insertSpaces:    true,
            wordWrap:        'off',
        });

        const btnSave = document.getElementById('btn-save');
        const btnSaveAs = document.getElementById('btn-save-as');

        function updateSaveButtons() {
            const currentCode = editor.getValue();
            const currentLang = langSelector.value;
            const isDirty = currentCode !== initialCode || currentLang !== initialLang;

            if (isDirty) {
                btnSave.classList.remove('d-none');
                if (preLoadedId) {
                    btnSaveAs.classList.remove('d-none');
                } else {
                    btnSaveAs.classList.add('d-none');
                }
            } else {
                btnSave.classList.add('d-none');
                btnSaveAs.classList.add('d-none');
            }
        }

        editor.onDidChangeModelContent(() => {
            updateSaveButtons();
        });

        langSelector.addEventListener('change', () => {
            updateSaveButtons();
        });

        // Ctrl+Enter → run
        editor.addCommand(
            monaco.KeyMod.CtrlCmd | monaco.KeyCode.Enter,
            () => runCode()
        );

        // Output editor (read-only, same language as source)
        outputEditor = monaco.editor.create(document.getElementById('output-panel-container'), {
            value:           preLoadedResult || localizedClickRun,
            language:        monacoLangMap[firstLang] ?? 'plaintext',
            theme:           'vs-dark',
            fontSize:        13,
            readOnly:        true,
            lineNumbers:     'off',
            minimap:         { enabled: false },
            scrollBeyondLastLine: false,
            automaticLayout: true,
            wordWrap:        'off',
            domReadOnly:     true,
            renderLineHighlight: 'none',
            scrollbar:       { vertical: 'auto', horizontal: 'auto' },
        });

        // Error editor (read-only, plaintext — compiler messages)
        errorEditor = monaco.editor.create(document.getElementById('error-panel-container'), {
            value:           preLoadedError || '',
            language:        'plaintext',
            theme:           'vs-dark',
            fontSize:        13,
            readOnly:        true,
            lineNumbers:     'off',
            minimap:         { enabled: false },
            scrollBeyondLastLine: false,
            automaticLayout: true,
            wordWrap:        'off',
            domReadOnly:     true,
            renderLineHighlight: 'none',
            scrollbar:       { vertical: 'auto', horizontal: 'auto' },
        });

        if (preLoadedResultCode !== null) {
            lastResultCode = preLoadedResultCode;
            const exitOk = preLoadedResultCode === 0;
            const isTimeout = preLoadedResultCode === 124;

            if (isTimeout) {
                badgeEl.textContent = localizedTimeout;
                badgeEl.className   = 'result-badge badge bg-warning text-dark';
            } else {
                badgeEl.textContent = localizedExit + ' ' + preLoadedResultCode;
                badgeEl.className   = 'result-badge badge ' + (exitOk ? 'bg-success' : 'bg-danger');
            }
        }

        // Tint error editor tokens red via built-in override
        monaco.editor.defineTheme('error-dark', {
            base: 'vs-dark',
            inherit: true,
            rules: [{ token: '', foreground: 'f87171' }],
            colors: {},
        });
        monaco.editor.setTheme('vs-dark'); // keep main theme
        errorEditor.updateOptions({ theme: 'error-dark' });

        // Language selector change
        langSelector.addEventListener('change', function () {
            const langName  = this.value;
            const monacoId  = monacoLangMap[langName] ?? 'plaintext';

            monaco.editor.setModelLanguage(editor.getModel(), monacoId);
            editor.setValue(langDefaults[langName] ?? '');

            monaco.editor.setModelLanguage(outputEditor.getModel(), monacoId);
            outputEditor.setValue('');
            errorEditor.setValue('');
            badgeEl.className = 'result-badge d-none';
            statusEl.textContent = '';
        });

        // Check if we have code in localStorage (from a guest redirect)
        const savedData = localStorage.getItem('cpprunner_pending_save');
        if (savedData && @Json.Serialize(User.Identity?.IsAuthenticated ?? false)) {
            const data = JSON.parse(savedData);
            editor.setValue(data.code);
            langSelector.value = data.lang;
            monaco.editor.setModelLanguage(editor.getModel(), monacoLangMap[data.lang] ?? 'plaintext');
            
            // Show the modal
            const modal = new bootstrap.Modal(document.getElementById('saveCodeModal'));
            modal.show();
            localStorage.removeItem('cpprunner_pending_save');
        }
    });

    // ── Save code ─────────────────────────────────────────────────────────────
    const saveCodeModalEl = document.getElementById('saveCodeModal');
    const codeTitleInput  = document.getElementById('code-title');
    const isPublicSwitch  = document.getElementById('is-public-switch');
    const saveResultSwitch = document.getElementById('save-result-switch');
    const btnConfirmSave  = document.getElementById('btn-confirm-save');
    let currentIdToSave = null;

    function handleSave(isSaveAs) {
        const isAuthenticated = @Json.Serialize(User.Identity?.IsAuthenticated ?? false);
        if (!isAuthenticated) {
            // Save to localStorage and redirect
            const data = {
                code: editor.getValue(),
                lang: langSelector.value
            };
            localStorage.setItem('cpprunner_pending_save', JSON.stringify(data));
            window.location.href = '/Account/Login?returnUrl=' + encodeURIComponent(window.location.pathname + window.location.search);
            return;
        }

        const preLoadedId = @Json.Serialize(Model.PreLoadedId);
        const preLoadedTitle = @Json.Serialize(Model.PreLoadedTitle);

        if (isSaveAs) {
            currentIdToSave = null;
            codeTitleInput.value = preLoadedTitle ? (preLoadedTitle + ' - Copy') : '';
        } else {
            currentIdToSave = preLoadedId;
            codeTitleInput.value = preLoadedTitle ?? '';
        }

        const modal = new bootstrap.Modal(saveCodeModalEl);
        modal.show();
    }

    async function confirmSave() {
        const title = codeTitleInput.value.trim();
        if (!title) {
            alert('@Localizer["Please enter a title."]');
            return;
        }

        const code = editor.getValue();
        const lang = langSelector.value;
        const isPublic = isPublicSwitch.checked;
        const saveResult = saveResultSwitch.checked;
        const result = saveResult ? outputEditor.getValue() : null;
        const error = saveResult ? errorEditor.getValue() : null;
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

        btnConfirmSave.disabled = true;
        btnConfirmSave.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> @Localizer["Saving..."]';

        try {
            const formData = new FormData();
            formData.append('title', title);
            formData.append('code', code);
            formData.append('language', lang);
            formData.append('isPublic', isPublic);
            formData.append('saveResult', saveResult);
            if (saveResult) {
                formData.append('result', result);
                formData.append('error', error);
                if (lastResultCode !== null) {
                    formData.append('resultCode', lastResultCode);
                }
            }
            if (currentIdToSave) {
                formData.append('id', currentIdToSave);
            }
            formData.append('__RequestVerificationToken', token);

            const response = await fetch('/Codes/Save', {
                method: 'POST',
                body: formData
            });

            if (response.ok) {
                const modal = bootstrap.Modal.getInstance(saveCodeModalEl);
                modal.hide();
                alert('@Localizer["Code saved successfully!"]');
                window.location.href = '/Codes/Index';
            } else {
                const errorText = await response.text();
                alert('@Localizer["Failed to save code:"] ' + errorText);
            }
        } catch (err) {
            alert('@Localizer["An error occurred:"] ' + err);
        } finally {
            btnConfirmSave.disabled = false;
            btnConfirmSave.textContent = '@Localizer["Save"]';
        }
    }

    // ── Run code ──────────────────────────────────────────────────────────────
    let lastResultCode = null;

    async function runCode() {
        if (!editor) return;

        const lang = langSelector.value;
        const code = editor.getValue();

        btnRun.disabled = true;
        btnRun.innerHTML = '<span class="spinner-border" role="status"></span>&nbsp;' + localizedRunning;
        statusEl.textContent = '';
        if (outputEditor) outputEditor.setValue('');
        if (errorEditor)  errorEditor.setValue('');
        badgeEl.className = 'result-badge d-none';
        lastResultCode = null;

        const startTime = Date.now();

        try {
            const response = await fetch('/Runner/run?lang=' + encodeURIComponent(lang), {
                method:  'POST',
                headers: { 'Content-Type': 'text/plain' },
                body:    code
            });

            if (!response.ok) {
                if (errorEditor) errorEditor.setValue('HTTP ' + response.status + ': ' + response.statusText);
                return;
            }

            const result  = await response.json();
            const elapsed = ((Date.now() - startTime) / 1000).toFixed(2);
            lastResultCode = result.ResultCode;

            const monacoId = monacoLangMap[lang] ?? 'plaintext';

            if (outputEditor) {
                monaco.editor.setModelLanguage(outputEditor.getModel(), monacoId);
                outputEditor.setValue(result.Output || localizedNoOutput);
            }
            if (errorEditor) {
                errorEditor.setValue(result.Error || '');
            }

            const exitOk = result.ResultCode === 0;
            const isTimeout = result.ResultCode === 124;

            if (isTimeout) {
                badgeEl.textContent = localizedTimeout;
                badgeEl.className   = 'result-badge badge bg-warning text-dark';
                statusEl.textContent = localizedTimedOutAfter + ' ' + elapsed + 's';
            } else {
                badgeEl.textContent = localizedExit + ' ' + result.ResultCode;
                badgeEl.className   = 'result-badge badge ' + (exitOk ? 'bg-success' : 'bg-danger');
                statusEl.textContent = localizedCompletedIn + ' ' + elapsed + 's';
            }

        } catch (err) {
            if (errorEditor) errorEditor.setValue(String(err));
        } finally {
            btnRun.disabled = false;
            btnRun.innerHTML = '<i data-lucide="play" class="me-1" style="width:14px;height:14px;"></i> ' + localizedRun;
            if (typeof lucide !== 'undefined') lucide.createIcons();
        }
    }

    if (typeof lucide !== 'undefined') lucide.createIcons();
</script>
}
